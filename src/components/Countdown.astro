<div class="grid grid-cols-2 sm:grid-cols-4 gap-5 text-center justify-items-center">
    <div class="bg-neutral rounded-box text-neutral-content flex flex-col py-6 sm:p-2 w-full max-w-35 sm:max-w-none">
        <span class="countdown font-mono text-5xl flex justify-center">
            <span id="days" style="--value:00; --digits: 2;">00</span>
        </span>
        <span id="days-label">Días</span>
    </div>
    
    <div class="bg-neutral rounded-box text-neutral-content flex flex-col py-6 sm:p-2 w-full max-w-35 sm:max-w-none">
        <span class="countdown font-mono text-5xl flex justify-center">
            <span id="hours" style="--value:00; --digits: 2;">00</span>
        </span>
        <span id="hours-label">Horas</span>
    </div>

    <div class="bg-neutral rounded-box text-neutral-content flex flex-col py-6 sm:p-2 w-full max-w-35 sm:max-w-none">
        <span class="countdown font-mono text-5xl flex justify-center">
            <span id="minutes" style="--value:00; --digits: 2;">00</span>
        </span>
        <span id="minutes-label">Minutos</span>
    </div>

    <div class="bg-neutral rounded-box text-neutral-content flex flex-col py-6 sm:p-2 w-full max-w-35 sm:max-w-none">
        <span class="countdown font-mono text-5xl flex justify-center">
            <span id="seconds" style="--value:00; --digits: 2;">00</span>
        </span>
        <span id="seconds-label">Segundos</span>
    </div>
</div>

<script>
    function updateCountdown() {
        const europeFormatter = new Intl.DateTimeFormat("es-ES", {
            timeZone: "Europe/Madrid",
            year: "numeric", month: "2-digit", day: "2-digit",
            hour: "2-digit", minute: "2-digit", second: "2-digit",
            hour12: false,
        });

        function getEuropeNow() {
            const now = new Date();
            const parts = europeFormatter.formatToParts(now);
            const p: any = {};
            parts.forEach(part => p[part.type] = part.value);
            return new Date(p.year, p.month - 1, p.day, p.hour, p.minute, p.second);
        }

        // Configura la fecha objetivo (10 de marzo de 2026 a las 00:00)
        function getTargetDate() {
            return new Date(2026, 2, 10, 0, 0, 0); // 10 de marzo de 2026 a las 00:00 (mes 2 porque enero es 0)
        }

        let targetDate = getTargetDate();

        function tick() {
            const now = getEuropeNow();
            let diff = targetDate.getTime() - now.getTime();

            if (diff <= 0) {
                // Si ya pasó la fecha, mostrar 0 y detener la actualización
                diff = 0;
            }

            const d = Math.floor(diff / (1000 * 60 * 60 * 24));
            const h = Math.floor((diff / (1000 * 60 * 60)) % 24);
            const m = Math.floor((diff / (1000 * 60)) % 60);
            const s = Math.floor((diff / 1000) % 60);

            // Actualizar Números y Variable CSS para la animación de DaisyUI
            const updateEl = (id: string, val: number) => {
                const el = document.getElementById(id);
                if (el) {
                    el.style.setProperty("--value", String(val));
                }
            };

            updateEl("days", d);
            updateEl("hours", h);
            updateEl("minutes", m);
            updateEl("seconds", s);

            // Actualizar Textos (Singular/Plural)
            const setLabel = (id: string, val: number, sing: string, plur: string) => {
                const el = document.getElementById(id);
                if (el) el.textContent = val === 1 ? sing : plur;
            };

            setLabel("days-label", d, "Día", "Días");
            setLabel("hours-label", h, "Hora", "Horas");
            setLabel("minutes-label", m, "Minuto", "Minutos");
            setLabel("seconds-label", s, "Segundo", "Segundos");
        }

        tick();
        setInterval(tick, 1000);
    }

    // Ejecución compatible con Astro/SSR
    updateCountdown();
    document.addEventListener("astro:after-swap", updateCountdown);
</script>